# Copia este archivo como ".env" y coloca tu Personal Access Token de GitHub.
# El token necesita el scope "repo" para poder crear, editar (PATCH) y eliminar (DELETE) repositorios.
VITE_GITHUB_API_TOKEN=tu_token_aqui

# Opcional: solo si quieres apuntar a una URL base distinta de la API de GitHub.
# VITE_GITHUB_API_URL=https://api.github.com
